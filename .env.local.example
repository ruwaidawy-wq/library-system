# Google Apps Script Web App URL (Deploy as Web App แล้ว copy URL มาใส่ที่นี่)
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Shared secret ที่ backend (gas/code.gs) ใช้เช็คว่า request มาจากเว็บนี้จริง
# ต้องตั้งค่าให้ตรงกับ API_SECRET ใน gas/code.gs เป๊ะๆ ห้ามใส่ NEXT_PUBLIC_ (จะได้ไม่ถูกส่งไปฝั่ง browser)
GAS_SHARED_SECRET=your-own-random-secret-here
